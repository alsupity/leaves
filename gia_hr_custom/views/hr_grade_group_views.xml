<odoo>
    <!-- Job Grades Tree View -->
    <record id="view_hr_job_grade_tree" model="ir.ui.view">
        <field name="name">hr.job.grade.tree</field>
        <field name="model">hr.job.grade</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Job Grades Action -->
    <record id="action_hr_job_grade" model="ir.actions.act_window">
        <field name="name">Job Grades</field>
        <field name="res_model">hr.job.grade</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- Employee Groups Tree View -->
    <record id="view_hr_employee_group_tree" model="ir.ui.view">
        <field name="name">hr.employee.group.tree</field>
        <field name="model">hr.employee.group</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Employee Groups Action -->
    <record id="action_hr_employee_group" model="ir.actions.act_window">
        <field name="name">Employee Groups</field>
        <field name="res_model">hr.employee.group</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_hr_job_grade" name="Groups and Grades" parent="hr.menu_human_resources_configuration" sequence="10"/>
    <menuitem id="menu_action_hr_job_grade" name="Employee Grades" parent="menu_hr_job_grade" action="action_hr_job_grade"/>
    <menuitem id="menu_action_hr_employee_group" name="Employee Groups" parent="menu_hr_job_grade" action="action_hr_employee_group"/>
</odoo>
