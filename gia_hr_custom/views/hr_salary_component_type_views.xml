<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="hr_salary_component_type_view_tree" model="ir.ui.view">
        <field name="name">hr.salary.component.type.tree</field>
        <field name="model">hr.salary.component.type</field>
        <field name="arch" type="xml">
            <tree string="Salary Component Types">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="hr_salary_component_type_view_form" model="ir.ui.view">
        <field name="name">hr.salary.component.type.form</field>
        <field name="model">hr.salary.component.type</field>
        <field name="arch" type="xml">
            <form string="Salary Component Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="hr_salary_component_type_view_search" model="ir.ui.view">
        <field name="name">hr.salary.component.type.search</field>
        <field name="model">hr.salary.component.type</field>
        <field name="arch" type="xml">
            <search string="Salary Component Types">
                <field name="name"/>
                <field name="code"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_salary_component_type" model="ir.actions.act_window">
        <field name="name">Salary Component Types</field>
        <field name="res_model">hr.salary.component.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_hr_salary_component_type"
              name="Salary Component Types"
              parent="hr_payroll.menu_hr_salary_configuration"
              action="action_hr_salary_component_type"
              sequence="70"/>
</odoo>
